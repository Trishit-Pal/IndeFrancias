			"ipa": "ɛs.kə",
			"hindiGloss": "क्या (प्रश्न के लिए)",
			"englishGloss": "(question marker, yes/no)",
			"example": { "french": "Est-ce que tu aimes le thé ?", "englishGloss": "Do you like tea?" },
			"cefrLevel": "A1",
			"skills": ["spokenInteraction"]
		},
